{
  "manifest_version": 3,
  "name": "Spark — Importa LinkedIn",
  "version": "1.0.12",
  "description": "Legge il profilo LinkedIn aperto e invia i dati all'ATS Spark (ats-neon-pi.vercel.app).",
  "icons": {
    "16": "icons/spark-extension.png",
    "32": "icons/spark-extension.png",
    "48": "icons/spark-extension.png",
    "128": "icons/spark-extension.png"
  },
  "action": {
    "default_title": "Spark · Importa LinkedIn",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/spark-extension.png",
      "32": "icons/spark-extension.png",
      "48": "icons/spark-extension.png",
      "128": "icons/spark-extension.png"
    }
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://linkedin.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
