{
  "manifest_version": 3,
  "name": "TalentFlow ATS — Import LinkedIn",
  "version": "1.0.3",
  "description": "Estrae dati da un profilo LinkedIn e li invia a TalentFlow ATS (localhost).",
  "action": {
    "default_title": "Importa profilo in TalentFlow",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://linkedin.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://*.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": ["content-linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
