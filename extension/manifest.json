{
  "manifest_version": 3,
  "name": "TalentFlow ATS — Import LinkedIn",
  "version": "1.0.8",
  "description": "Estrae dati da un profilo LinkedIn e li invia a TalentFlow ATS (localhost).",
  "action": {
    "default_title": "Importa profilo in TalentFlow",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://linkedin.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
